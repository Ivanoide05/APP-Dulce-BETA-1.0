{
  "version": 2,
  "builds": [
    { "src": "login.html", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "admin.html", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "agenda.js", "use": "@vercel/static" },
    { "src": "clear-sw.js", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "backend/server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/server.js" },
    { "src": "/webhook/(.*)", "dest": "/backend/server.js" },
    { "src": "/health", "dest": "/backend/server.js" },
    { "src": "/", "dest": "/login.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
