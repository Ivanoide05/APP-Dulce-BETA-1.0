# ===== Dulce y Jaleo — Variables de entorno (PLANTILLA) =====
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git.

# Airtable — Datos de negocio
AIRTABLE_API_KEY=tu_airtable_personal_access_token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# IDs de tablas Airtable
TABLE_FACTURAS=tblXXXXXXXXXXXXX
TABLE_ALBARANES=tblXXXXXXXXXXXXX
TABLE_GASTOS_VARIOS=tblXXXXXXXXXXXXX

# Google Gemini — IA
GEMINI_API_KEY=tu_gemini_api_key

# Puerto del servidor
PORT=3001

# Supabase — Autenticación y usuarios
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-de-supabase

# JWT — Firma de tokens de sesión (generado con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=genera-con-crypto-randomBytes-64-hex
